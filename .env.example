# OpenAI API key (obrigatória)
OPENAI_API_KEY=sua-chave-openai-aqui

# Brave Search API key para busca web (obrigatória)
BRAVE_API_KEY=sua-chave-brave-aqui
RETRIEVER=brave

# ──────────────────────────────────────────────
# Configuração do GPT Researcher
# ──────────────────────────────────────────────

# Modelo de embedding
EMBEDDING=openai:text-embedding-3-small

# LLM para pesquisa estratégica (use gpt-4o-mini para maior velocidade)
STRATEGIC_LLM=openai:gpt-4o-mini

# Número máximo de iterações de pesquisa (use 2 para maior velocidade)
MAX_ITERATIONS=2

# ──────────────────────────────────────────────
# Configuração do Servidor MCP
# ──────────────────────────────────────────────

# Transporte: stdio (padrão, uso com Nanobot/Claude Desktop) | sse | streamable-http
MCP_TRANSPORT=stdio

# Host e porta (apenas para transporte sse/streamable-http)
MCP_HOST=0.0.0.0
PORT=8000

# Nível de log
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Configuração Opcional: Anthropic (Claude)
# ──────────────────────────────────────────────
# ANTHROPIC_API_KEY=sua-chave-anthropic-aqui

# ──────────────────────────────────────────────
# Integração com Nanobot
# ──────────────────────────────────────────────
# Para uso via Nanobot, configure em ~/.nanobot/config.yml:
#
# tools:
#   mcp_servers:
#     gptr:
#       type: stdio
#       command: uv
#       args:
#         - run
#         - --project
#         - /caminho/absoluto/para/gptr-mcp-master
#         - gptr-mcp
#       env:
#         OPENAI_API_KEY: "sua-chave-aqui"
#         BRAVE_API_KEY: "sua-chave-aqui"
#         RETRIEVER: "brave"