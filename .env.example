# =============================================================
# Percival Deep Research MCP — environment template
# Copy this file to ".env" and fill in the real values.
# Never commit ".env" to version control.
# =============================================================
#
# ─── v2.2.0 simplified config ────────────────────────────────
# The server now uses ONE LLM endpoint (`INFERENCE_*`) instead of
# the four OpenAI-style variables. Setting up a new instance is now:
#
#   1. (Optional) INFERENCE_BASE_URL — if you use a custom gateway
#      (Venice, MiniMax, OpenRouter, or any OpenAI-compatible URL).
#      The server will auto-detect the provider from the URL host.
#   2. INFERENCE_API_KEY — credential for that endpoint.
#   3. INFERENCE_LLM — model name, e.g. "gpt-4o-mini",
#      "claude-3-haiku-20240307", "llama-3.3-70b". The server
#      uses this SAME LLM for ALL tasks (research, summary,
#      embedding) — unless you override per slot (FAST_LLM,
#      SMART_LLM, etc.; legacy).
#   4. RETRIEVER — default is `duckduckgo` (no API key needed).
#      Set to `brave` if you want to use Brave Search (and set
#      BRAVE_API_KEY).
# ──────────────────────────────────────────────────────────────

# ─── Inference (v2.2.0: canônico) ────────────────────────────
INFERENCE_API_KEY=sua-chave-aqui
# Optional: gateway compatível com OpenAI. Com base no host,
# o servidor detecta o provider e o alias:
#   - https://api.openai.com/v1            → openai (default)
#   - https://api.venice.ai/api/v1        → venice
#   - https://api.minimax.io/v1           → minimax
#   - https://openrouter.ai/api/v1        → openrouter
# Outros URLs → openai (sem alias).
# INFERENCE_BASE_URL=

# O MESMO LLM é usado para FAST/SMART/STRATEGIC/EMBEDDING.
# Não precisa setar mais nada aqui.
INFERENCE_LLM=openai:gpt-4o-mini

# ─── Retriever (v2.2.0: default mudou para duckduckgo) ───────
# duckduckgo não precisa de chave de API.
# Para voltar para brave, descomente as linhas abaixo:
# RETRIEVER=brave
# BRAVE_API_KEY=sua-chave-brave

# ─── Legacy (deprecated, ainda suportado com WARN logado) ────
# Substitua por INFERENCE_API_KEY / INFERENCE_BASE_URL / INFERENCE_LLM.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# FAST_LLM=
# SMART_LLM=
# STRATEGIC_LLM=
# EMBEDDING_LLM=
# PERCIVAL_LLM_PROVIDER_ALIASES=
# MINIMAX_MODEL_ALIAS=
# MINIMAX_ALIAS_PATTERN=

# ─── Configuração do Servidor MCP ────────────────────────────

# Transporte: stdio (padrão, uso com Nanobot/Claude Desktop) | sse | streamable-http
MCP_TRANSPORT=stdio

# Host e porta (apenas para transporte sse/streamable-http)
MCP_HOST=0.0.0.0
PORT=8000

# Nível de log
LOG_LEVEL=INFO

# ─── Tuning (v2.0+) ──────────────────────────────────────────
# Tempo máximo (s) para uma pesquisa completa (default: 90)
PERCIVAL_RESEARCH_TIMEOUT_S=90

# Pesquisas concorrentes (default: 3)
PERCIVAL_MAX_CONCURRENT_RESEARCH=3
